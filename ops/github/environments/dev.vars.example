# Non-sensitive values for the dev GitHub environment.
# Copy to dev.vars and replace placeholders.

GCP_PROJECT_ID=<gcp-project-id>
GCP_REGION=europe-west1
GCP_ARTIFACT_REGION=europe-west1
GCP_ARTIFACT_REPOSITORY=hjertefrisk
GCP_WORKLOAD_IDENTITY_PROVIDER=projects/<project-number>/locations/global/workloadIdentityPools/<pool>/providers/<provider>
GCP_SERVICE_ACCOUNT_EMAIL=github-actions@<gcp-project-id>.iam.gserviceaccount.com
GCP_BACKEND_SERVICE=hjertefrisk-backend-dev
GCP_FRONTEND_SERVICE=hjertefrisk-frontend-dev
GCP_BACKEND_IMAGE=hjertefrisk-backend
GCP_FRONTEND_IMAGE=hjertefrisk-frontend
GCP_BACKEND_MEMORY=1Gi
GCP_FRONTEND_MEMORY=512Mi
GCP_BACKEND_CPU=1
GCP_FRONTEND_CPU=1
RUN_DB_MIGRATIONS=false
FRONTEND_ORIGINS=https://hjertefrisk-dev.naerverk.no
NEXT_PUBLIC_API_URL=https://hjertefrisk-dev.naerverk.no
API_URL_INTERNAL=https://hjertefrisk-dev.naerverk.no
NEXT_PUBLIC_SUPABASE_URL=https://bjaelyslokajmrpzbnzw.supabase.co
