# Sensitive values for the staging GitHub environment.
# Copy to staging.secrets and replace placeholders.
# Supabase__AnonKey is the environment's anon key.
# It is the same value frontend would use as NEXT_PUBLIC_SUPABASE_ANON_KEY.

SUPABASE_DB_URL=<supabase-db-url>
Supabase__AnonKey=<supabase-anon-key>
ConnectionStrings__Default=<supabase-db-url>
